# Server
SERVER_PORT=8080

# Supabase PostgreSQL (Connection Pooler 권장: Session mode, port 5432)
# Supabase Dashboard → Project Settings → Database → Connection string
DB_URL=jdbc:postgresql://aws-0-<region>.pooler.supabase.com:5432/postgres
DB_USERNAME=postgres.<project-ref>
DB_PASSWORD=

# JWT
# 256-bit 이상 랜덤 문자열 (예: openssl rand -base64 32)
JWT_SECRET=
# 토큰 유효 기간 (ms), 기본값 86400000 (24h)
JWT_EXPIRATION_MS=86400000

# Admin 계정 (Phase 4에서 사용)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=

# Supabase Storage (Phase 5에서 사용)
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=blog-images
